// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  TEACHER
  STUDENT
}

enum Semester {
  GANJIL
  GENAP
}

enum GradeCategory {
  PH
  STS
  SAS
}

enum Resource {
  USER
  COURSE
  GRADE
  CATEGORY
}

model User {
  id           String   @id @default(uuid())
  email        String?  @unique
  username     String   @unique
  password     String
  fullname     String
  role         Role
  moodleUserId Int?     @unique
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student Student?
  teacher Teacher?
}

model Student {
  id              String           @id @default(uuid())
  userId          String           @unique
  user            User             @relation(fields: [userId], references: [id])
  nis             String           @unique
  classes         StudentClass[]
  gradeComponents GradeComponent[]
  gradeSummaries  GradeSummary[]

  enrollments Enrollment[]
}

model Teacher {
  id        String               @id @default(uuid())
  userId    String               @unique
  user      User                 @relation(fields: [userId], references: [id])
  nip       String               @unique
  teachings TeachingAssignment[]
  homerooms HomeroomAssignment[]
}

model AcademicYear {
  id       String  @id @default(uuid())
  name     String  @unique
  isActive Boolean @default(false)
  isLocked Boolean @default(false)
  // contoh:
  // 2025/2026

  studentClasses      StudentClass[]
  teachingAssignments TeachingAssignment[]

  homeroomAssignments HomeroomAssignment[]
}

model Classroom {
  id        String               @id @default(uuid())
  name      String
  level     Int
  students  StudentClass[]
  teachings TeachingAssignment[]
  homerooms HomeroomAssignment[]
}

model Subject {
  id        String               @id @default(uuid())
  code      String               @unique
  name      String
  teachings TeachingAssignment[]
}

model StudentClass {
  id             String       @id @default(cuid())
  studentId      String
  classroomId    String
  academicYearId String
  student        Student      @relation(fields: [studentId], references: [id])
  classroom      Classroom    @relation(fields: [classroomId], references: [id])
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  @@unique([studentId, academicYearId])
}

model TeachingAssignment {
  id String @id @default(cuid())

  teacherId      String
  subjectId      String
  classroomId    String
  academicYearId String
  courseId       Int    @unique

  teacher      Teacher      @relation(fields: [teacherId], references: [id])
  subject      Subject      @relation(fields: [subjectId], references: [id])
  classroom    Classroom    @relation(fields: [classroomId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  course Course @relation(fields: [courseId], references: [id])

  gradeSummaries  GradeSummary[]

  @@unique([teacherId, subjectId, classroomId, academicYearId])
}

model HomeroomAssignment {
  id             String       @id @default(uuid())
  teacherId      String
  classroomId    String
  academicYearId String
  teacher        Teacher      @relation(fields: [teacherId], references: [id])
  classroom      Classroom    @relation(fields: [classroomId], references: [id])
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  @@unique([classroomId, academicYearId])
  @@unique([teacherId, academicYearId])
}

model Course {
  id Int @id // courseId = Moodle courseId

  fullname   String
  shortname  String
  categoryId Int
  visible    Boolean
  createdAt  DateTime @default(now())

  updatedAt DateTime @updatedAt

  lastSync DateTime?
  category CourseCategory @relation(fields: [categoryId], references: [id])

  teaching   TeachingAssignment?
  gradeItems GradeItem[]

  enrollments Enrollment[]
}

model CourseCategory {
  id       Int      @id // courseCategoryId = Mooodle courseCategoryId
  name     String
  parentId Int?
  depth    Int
  courses  Course[]
}

model GradeItem {
  id              Int              @id
  courseId        Int
  name            String
  itemType        String?
  category        GradeCategory?
  course          Course           @relation(fields: [courseId], references: [id])
  gradeComponents GradeComponent[]
}

model GradeComponent {
  id String @id @default(uuid())

  studentId   String
  gradeItemId Int

  score    Float
  lastSync DateTime?

  student              Student             @relation(fields: [studentId], references: [id])
  gradeItem            GradeItem           @relation(fields: [gradeItemId], references: [id])

  @@unique([studentId, gradeItemId])
}

model GradeSummary {
  id           String             @id @default(uuid())
  studentId    String
  teachingId   String
  semester     Semester
  category     GradeCategory
  score        Float
  calculatedAt DateTime           @default(now())
  student      Student            @relation(fields: [studentId], references: [id])
  teaching     TeachingAssignment @relation(fields: [teachingId], references: [id])

  updatedAt DateTime @updatedAt

  @@unique([studentId, teachingId, semester, category])
}

model Enrollment {
  id        String  @id @default(uuid())
  studentId String
  courseId  Int
  student   Student @relation(fields: [studentId], references: [id])
  course    Course  @relation(fields: [courseId], references: [id])

  @@unique([studentId, courseId])
}

model SchoolSetting {
  id          String  @id @default(uuid())
  schoolName  String?
  moodleUrl   String?
  moodleToken String? @db.Text

  syncEnabled  Boolean @default(true)
  syncInterval Int     @default(30) // menit

  logo      String?
  updatedAt DateTime @updatedAt
}

model SyncLog {
  id       String   @id @default(uuid())
  resource Resource
  status   String
  message  String?
  syncedAt DateTime @default(now())
}
