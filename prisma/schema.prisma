// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  TEACHER
  STUDENT
}

enum GradeCategory {
  PH
  STS
  SAS
}

enum Resource {
  USER
  COURSE
  GRADE
  CATEGORY
}

enum SemesterType {
  GANJIL
  GENAP
}

model User {
  id           String   @id @default(uuid())
  email        String?  @unique
  username     String   @unique
  password     String
  fullname     String
  role         Role
  moodleUserId Int?     @unique
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student Student?
  teacher Teacher?
}

model Student {
  id              String           @id @default(uuid())
  userId          String           @unique
  user            User             @relation(fields: [userId], references: [id])
  nis             String           @unique
  classes         StudentClass[]
  gradeComponents GradeComponent[]
  gradeSummaries  GradeSummary[]

  enrollments Enrollment[]
}

model Teacher {
  id        String               @id @default(uuid())
  userId    String               @unique
  user      User                 @relation(fields: [userId], references: [id])
  nip       String               @unique
  teachings TeachingAssignment[]
  homerooms HomeroomAssignment[]
}

model AcademicYear {
  id String @id @default(uuid())

  name String @unique

  isActive Boolean @default(false)
  isLocked Boolean @default(false)

  semesters Semester[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Semester {
  id String @id @default(uuid())

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  type SemesterType

  isActive Boolean @default(false)
  isLocked Boolean @default(false)

  studentClasses      StudentClass[]
  teachingAssignments TeachingAssignment[]
  homeroomAssignments HomeroomAssignment[]
  gradeSummaries GradeSummary[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([academicYearId, type])
  @@index([academicYearId])
  @@index([isActive])
}

model Classroom {
  id        String               @id @default(uuid())
  name      String
  level     Int
  room      String
  building  String
  floor     Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  students  StudentClass[]
  teachings TeachingAssignment[]
  homerooms HomeroomAssignment[]
}

model Subject {
  id        String               @id @default(uuid())
  code      String               @unique
  name      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  teachings TeachingAssignment[]
}

model StudentClass {
  id          String    @id @default(cuid())
  studentId   String
  classroomId String
  semesterId  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  student     Student   @relation(fields: [studentId], references: [id])
  classroom   Classroom @relation(fields: [classroomId], references: [id])
  semester    Semester  @relation(fields: [semesterId], references: [id])

  @@unique([studentId, semesterId])
}

model TeachingAssignment {
  id String @id @default(cuid())

  teacherId   String
  subjectId   String
  classroomId String
  semesterId  String
  courseId    Int    @unique

  teacher   Teacher   @relation(fields: [teacherId], references: [id])
  subject   Subject   @relation(fields: [subjectId], references: [id])
  classroom Classroom @relation(fields: [classroomId], references: [id])
  semester  Semester  @relation(fields: [semesterId], references: [id])

  course Course @relation(fields: [courseId], references: [id])

  gradeSummaries GradeSummary[]

  @@unique([teacherId, subjectId, classroomId, semesterId])
}

model HomeroomAssignment {
  id          String    @id @default(uuid())
  teacherId   String
  classroomId String
  semesterId  String
  teacher     Teacher   @relation(fields: [teacherId], references: [id])
  classroom   Classroom @relation(fields: [classroomId], references: [id])
  semester    Semester  @relation(fields: [semesterId], references: [id])

  @@unique([classroomId, semesterId])
  @@unique([teacherId, semesterId])
}

model Course {
  id Int @id // courseId = Moodle courseId

  fullname   String
  shortname  String
  categoryId Int
  visible    Boolean
  createdAt  DateTime @default(now())

  updatedAt DateTime @updatedAt

  lastSync DateTime?
  category CourseCategory @relation(fields: [categoryId], references: [id])

  teaching   TeachingAssignment?
  gradeItems GradeItem[]

  enrollments Enrollment[]
}

model CourseCategory {
  id       Int      @id // courseCategoryId = Mooodle courseCategoryId
  name     String
  parentId Int?
  depth    Int
  courses  Course[]
}

model GradeItem {
  id              Int              @id
  courseId        Int
  name            String
  itemType        String?
  category        GradeCategory?
  course          Course           @relation(fields: [courseId], references: [id])
  gradeComponents GradeComponent[]
}

model GradeComponent {
  id String @id @default(uuid())

  studentId   String
  gradeItemId Int

  score    Float
  isManual Boolean   @default(false)
  lastSync DateTime?

  student   Student   @relation(fields: [studentId], references: [id])
  gradeItem GradeItem @relation(fields: [gradeItemId], references: [id])

  @@unique([studentId, gradeItemId])
}

model GradeSummary {
  id           String             @id @default(uuid())
  studentId    String
  teachingId   String
  semesterId     String
  category     GradeCategory
  score        Float
  calculatedAt DateTime           @default(now())
  student      Student            @relation(fields: [studentId], references: [id])
  teaching     TeachingAssignment @relation(fields: [teachingId], references: [id])
  semester Semester @relation(fields: [semesterId], references: [id])

  updatedAt DateTime @updatedAt

  @@unique([studentId, teachingId, semesterId, category])
}

model Enrollment {
  id        String  @id @default(uuid())
  studentId String
  courseId  Int
  student   Student @relation(fields: [studentId], references: [id])
  course    Course  @relation(fields: [courseId], references: [id])

  @@unique([studentId, courseId])
}

model SchoolSetting {
  id          String  @id @default(uuid())
  schoolName  String?
  moodleUrl   String?
  moodleToken String? @db.Text

  syncEnabled  Boolean @default(true)
  syncInterval Int     @default(30) // menit

  logo      String?
  updatedAt DateTime @updatedAt
}

model SyncLog {
  id       String   @id @default(uuid())
  resource Resource
  status   String
  message  String?
  syncedAt DateTime @default(now())
}
